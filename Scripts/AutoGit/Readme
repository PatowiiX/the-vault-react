# Ver quién causó el último auto-commit
python3 git_automation.py auto audit --limit 5

# Ver cola FIFO
python3 git_automation.py auto fifo --show

# Deshacer último auto-commit (preservando cambios)
python3 git_automation.py auto rollback --keep-changes

# Modificar mensaje del último commit
python3 git_automation.py auto amend -m "Mensaje corregido"

# Pausar auto-commit temporalmente
python3 git_automation.py auto toggle --off

# Reanudar auto-commit
python3 git_automation.py auto toggle --on

# Ver configuración actual
python3 git_automation.py auto config --show

# Cambiar límite de FIFO a 15
python3 git_automation.py auto config --set max_fifo_size 15

# Cambiar intervalo mínimo entre auto-commits a 10 minutos
python3 git_automation.py auto config --set min_interval_minutes 10

